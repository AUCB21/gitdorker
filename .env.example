# Path to the Python binary that runs gitdorker.
# Defaults: Windows venv → ../env/Scripts/python
#           Unix venv    → ../env/bin/python
#           Fallback     → python3 (must be on PATH)
PYTHON_BIN=

# Directory where gitdorker writes markdown reports.
# Defaults to ../reports relative to the ui/ directory.
GITDORKER_REPORTS_DIR=
